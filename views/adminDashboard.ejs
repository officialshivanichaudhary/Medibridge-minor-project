<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Admin Dashboard</title>

<style>
body {
    background: url('/images/medibridge_landingpage.jpg') no-repeat center/cover fixed;
    font-family: "Segoe UI", sans-serif;
    margin: 0;
    padding: 0;
}
body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    z-index: -1;
}
.admin-container {
    width: 96%;
    margin: 30px auto;
    padding: 0 10px;
}

.section-card {
    background: rgba(255,255,255,0.95);
    padding: 25px 30px;
    margin-top: 25px;
    margin-left: 180px;
    margin-right: 180px;
    border-radius: 18px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.22);
}

h1 {
    text-align: center;
    font-size: 2rem;
    font-weight: 800;
    color: #f4f7f9;
}
h2 {
    margin-bottom: 15px;
    font-weight: 800;
    color: #064663;
}

/* GRID FOR RESOURCE BOXES */
.resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
    margin-bottom: 20px;
}
.resource-box {
    background: #ffffffcc;
    border-radius: 14px;
    padding: 18px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    border-left: 5px solid #0077b6;
}
.resource-box h4 {
    color: #0077b6;
    font-size: 1.1rem;
    margin-bottom: 10px;
}
.save-btn {
    width: auto !important;   /* 🔥 override */
    padding: 8px 16px;
    font-size: 0.9rem;
    border-radius: 8px;
    display: block;
    margin: 10px auto;
}
/* INPUTS */
input, select {
    width: 100%;
    padding: 9px;
    border-radius: 8px;
    font-size: 0.95rem;
    border: 1.5px solid rgba(0,0,0,0.25);
    margin-bottom: 12px;
}
input:focus, select:focus {
    border-color: #0077b6;
    outline: none;
    box-shadow: 0 0 5px rgba(0,119,182,0.5);
}

/* BUTTONS */
button, .btn-outline-primary {
    padding: 12px;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 10px;
    cursor: pointer;
    transition: 0.3s;
}
button {
    width: 200px;
    background: #0077b6;
    color: white;
    border: none;
   
}
button:hover {
    background: #005f87;
}
.btn-outline-primary {
    border: 2px solid #0077b6;
    color: #0077b6;
    background: transparent;
    margin-top: 15px;
    text-decoration: none;
    display: inline-block;
}
.btn-outline-primary:hover {
    background: #0077b6;
    color: #fff;
}

/* LINKS */
a {
    text-decoration: none;
    font-weight: 600;
    color: #034694;
}
a:hover {
    text-decoration: underline;
}
.resources-grid button {
    grid-column: 1 / -1;
    justify-self: start;   /* 🔥 left align */
    margin-left: 0;}

</style>

</head>
<body>

<div class="admin-container">

<h1>Admin Dashboard</h1>

<!-- 🏥 Hospital Resources Section -->
<div class="section-card">
<h2>Hospital Resources</h2>

<form action="/admin/update-hospital-resources" method="POST" class="resources-grid">
    <!-- ICU -->
    <div class="resource-box">
        <h4>ICU Beds</h4>
        <label>Total</label>
        <input type="number" name="icu_total" value="<%= resources.beds.icu.total %>" />
        <label>Occupied</label>
        <input type="number" name="icu_occupied" value="<%= resources.beds.icu.occupied %>" />
    </div>

    <!-- General -->
    <div class="resource-box">
        <h4>General Beds</h4>
        <label>Total</label>
        <input type="number" name="general_total" value="<%= resources.beds.general.total %>" />
        <label>Occupied</label>
        <input type="number" name="general_occupied" value="<%= resources.beds.general.occupied %>" />
    </div>

    <!-- HDU -->
    <div class="resource-box">
        <h4>HDU Beds</h4>
        <label>Total</label>
        <input type="number" name="hdu_total" value="<%= resources.beds.hdu.total %>" />
        <label>Occupied</label>
        <input type="number" name="hdu_occupied" value="<%= resources.beds.hdu.occupied %>" />
    </div>

    <!-- Private Room -->
    <div class="resource-box">
        <h4>Private Rooms</h4>
        <label>Total</label>
        <input type="number" name="private_total" value="<%= resources.beds.privateRoom.total %>" />
        <label>Occupied</label>
        <input type="number" name="private_occupied" value="<%= resources.beds.privateRoom.occupied %>" />
    </div>

    <!-- Emergency -->
    <div class="resource-box">
        <h4>Emergency Beds</h4>
        <label>Total</label>
        <input type="number" name="emergency_total" value="<%= resources.beds.emergency.total %>" />
        <label>Occupied</label>
        <input type="number" name="emergency_occupied" value="<%= resources.beds.emergency.occupied %>" />
    </div>

    <!-- Oxygen -->
    <div class="resource-box">
        <h4>Oxygen Cylinders</h4>
        <label>Total</label>
        <input type="number" name="oxygen_total" value="<%= resources.oxygenCylinders.total %>" />
        <label>Used</label>
        <input type="number" name="oxygen_used" value="<%= resources.oxygenCylinders.used %>" />
    </div>

    <!-- Ventilators -->
    <div class="resource-box">
        <h4>Ventilators</h4>
        <label>Total</label>
        <input type="number" name="ventilator_total" value="<%= resources.ventilators.total %>" />
        <label>Used</label>
        <input type="number" name="ventilator_used" value="<%= resources.ventilators.used %>" />
    </div>
<button type="submit" class="save-btn">Save Data</button>
</form>

</div>


<!-- 🩸 Blood Bank Section -->
<div class="section-card">
<h2>Blood Bank</h2>
<form action="/admin/update-blood-stock" method="POST">

    <div class="resources-grid">
    <% Object.keys(resources.bloodStock).forEach(group => { %>
      <div class="resource-box">
          <label><%= group %> Units</label>
          <input type="number" name="blood_<%= group %>" value="<%= resources.bloodStock[group] %>" />
      </div>
    <% }) %>
    </div>

    <button type="submit">Save Blood Data</button>
</form>
</div>


<!-- 👨‍⚕️ Doctors Section -->
<div class="section-card">
<h2>Doctors</h2>
<a href="/admin/doctors">Manage Doctors</a>
</div>

<!-- 🎫 Offline Token -->
<div class="section-card">
<h2>Generate Offline Token</h2>
<form method="POST" action="/admin/generate-offline-token">

  <label>Patient Name:</label>
  <input type="text" name="patientName" required>

  <label>Choose Department:</label>
  <select name="department" required>
      <option value="">Select Department</option>
      <option value="Cardiology">Cardiology</option>
      <option value="Dermatology">Dermatology</option>
      <option value="ENT">ENT</option>
      <option value="Orthopedics">Orthopedics</option>
      <option value="General Medicine">General Medicine</option>
  </select>

  <button type="submit">Generate Token</button>

</form>

<h3>Today's Offline Tokens</h3>
<a href="/admin/offline-tokens">View Tokens</a>
<br>
<a href="/" class="btn-outline-primary">Go to Home</a>
</div>

</div>
</body>
</html>
