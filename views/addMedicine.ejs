<%- include('partials/header') %>

<h3>Add New Medicine</h3>
<form action="/api/medicines/add" method="POST" class="mt-3">
  <div class="mb-2">
    <label>Medicine Name</label>
    <input type="text" name="name" class="form-control" required>
  </div>
  <div class="mb-2">
    <label>Batch Number</label>
    <input type="text" name="batchNumber" class="form-control">
  </div>
  <div class="mb-2">
    <label>Quantity</label>
    <input type="number" name="quantity" class="form-control">
  </div>
  <div class="mb-2">
    <label>Manufacture Date</label>
    <input type="date" name="manufactureDate" class="form-control">
  </div>
  <div class="mb-2">
    <label>Expiry Date</label>
    <input type="date" name="expiryDate" class="form-control" required>
  </div>
  <div class="mb-2">
    <label>Supplier</label>
    <input type="text" name="supplier" class="form-control">
  </div>
  <button class="btn btn-primary mt-2">Add Medicine</button>
</form>

<%- include('partials/footer') %>
