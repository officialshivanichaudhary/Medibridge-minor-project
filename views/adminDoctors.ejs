


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>

<style>
body {
    background: url('/images/medibridge_landingpage.jpg') center/cover fixed;
    font-family: "Segoe UI", sans-serif;
    margin: 0;
    padding-top: 90px;
}

body::before {
    content:"";
    position:fixed;
    inset:0;
    background:rgba(0,0,0,0.45);
    backdrop-filter:blur(5px);
    z-index:-1;
}

.doctor-container {
    width: 950px;
    margin: auto;
    background: rgba(255,255,255,0.94);
    padding: 30px 40px;
    border-radius: 20px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.26);
}

h1, h2 {
    color: #0077b6;
    font-weight: 800;
    margin-bottom: 18px;
}

form input, form select {
    width: 100%;
    padding: 12px;
    border-radius: 10px;
    border: 1.5px solid rgba(0,0,0,0.25);
    font-size: 1rem;
    margin-top: 10px;
}

form input:focus {
    border-color: #0077b6;
    outline: none;
    box-shadow: 0 0 6px rgba(0,119,182,0.35);
}

/* Buttons */
button {
    width: 100%;
    padding: 14px;
    background: #0077b6;
    color: white;
    font-weight: 700;
    border-radius: 10px;
    border: none;
    margin-top: 15px;
    cursor: pointer;
    font-size: 1.05rem;
}
button:hover {
    background: #005f87;
}

/* Table Styling */
table {
    width: 100%;
    background: rgba(255,255,255,0.95);
    border-collapse: collapse;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 6px 22px rgba(0,0,0,0.18);
}

thead {
    background: #0077b6;
    color: white;
}
th, td {
    padding: 13px;
    text-align: center;
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(0,0,0,0.12);
}
tbody tr:hover {
    background: #e8f7ff;
}

a {
    text-decoration: none;
    color: #004e76;
    font-weight: 600;
}
a:hover {
    color: #0097d0;
}

hr {
    opacity: 0.3;
    margin: 30px 0;
}

/* Checkbox layout */
.opd-days {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 10px;
}
.opd-days label {
    background: #e0f5ff;
    padding: 6px 10px;
    border-radius: 8px;
    color: #005a80;
    cursor: pointer;
    font-weight: 600;
}
.opd-days input {
    margin-right: 6px;
    width: auto;
}
</style>



</head>
<body>
  <div class="doctor-container">
<h1>Manage Doctors</h1>

<!-- Add Doctor Form -->
<h2>Add New Doctor</h2>

<form method="POST" action="/admin/add-doctor">
  <input type="text" name="name" placeholder="Doctor Name" required>
  <input type="text" name="department" placeholder="Department" required>

  <input type="number" name="maxPatientsPerDay" placeholder="Max Patients" required>
  <input type="number" name="avgConsultTime" placeholder="Consult Time (min)" required>

  <!-- ✅ OPD days selection -->
  <div style="margin-top:8px;">
    <label><b>OPD Days:</b></label><br>
    <% const allDays = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]; %>
    <% allDays.forEach(d => { %>
      <label style="margin-right:10px;">
        <input type="checkbox" name="opdDays" value="<%= d %>">
        <%= d %>
      </label>
    <% }) %>
  </div>

  <!-- ✅ Limits -->
  <div style="margin-top:8px;">
    <label>Max Leave / Month:</label>
    <input type="number" name="maxLeavePerMonth" min="0" value="4" style="width:80px;">
    
    <label style="margin-left:12px;">Offline Reserve %:</label>
    <input type="number" name="offlineReservePercent" min="0" max="100" value="20" style="width:80px;">
  </div>

  <button type="submit" style="margin-top:10px;">Add Doctor</button>
</form>

<hr>

<h2>Existing Doctors</h2>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Department</th>
      <th>Max Patients</th>
      <th>Avg Time</th>
      <th>OPD Days</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% doctors.forEach(d => { %>
      <tr>
        <td><%= d.name %></td>
        <td><%= d.department %></td>
        <td><%= d.maxPatientsPerDay %></td>
        <td><%= d.avgConsultTime %></td>

        <!-- ✅ show OPD days decided by admin -->
        <td><%= (d.opdDays || []).join(", ") %></td>

        <td>
          <a href="/admin/edit-doctor/<%= d._id %>">Edit</a> |
          <a href="/admin/doctors/<%= d._id %>/leave">Manage Leave</a> |
          <a href="/admin/delete-doctor/<%= d._id %>">Delete</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
</div>


</body>
</html>

