
<h1>Manage Doctors</h1>

<!-- Add Doctor Form -->
<h2>Add New Doctor</h2>

<form method="POST" action="/admin/add-doctor">
  <input type="text" name="name" placeholder="Doctor Name" required>
  <input type="text" name="department" placeholder="Department" required>

  <input type="number" name="maxPatientsPerDay" placeholder="Max Patients" required>
  <input type="number" name="avgConsultTime" placeholder="Consult Time (min)" required>

  <!-- ✅ OPD days selection -->
  <div style="margin-top:8px;">
    <label><b>OPD Days:</b></label><br>
    <% const allDays = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]; %>
    <% allDays.forEach(d => { %>
      <label style="margin-right:10px;">
        <input type="checkbox" name="opdDays" value="<%= d %>">
        <%= d %>
      </label>
    <% }) %>
  </div>

  <!-- ✅ Limits -->
  <div style="margin-top:8px;">
    <label>Max Leave / Month:</label>
    <input type="number" name="maxLeavePerMonth" min="0" value="4" style="width:80px;">
    
    <label style="margin-left:12px;">Offline Reserve %:</label>
    <input type="number" name="offlineReservePercent" min="0" max="100" value="20" style="width:80px;">
  </div>

  <button type="submit" style="margin-top:10px;">Add Doctor</button>
</form>

<hr>

<h2>Existing Doctors</h2>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Department</th>
      <th>Max Patients</th>
      <th>Avg Time</th>
      <th>OPD Days</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% doctors.forEach(d => { %>
      <tr>
        <td><%= d.name %></td>
        <td><%= d.department %></td>
        <td><%= d.maxPatientsPerDay %></td>
        <td><%= d.avgConsultTime %></td>

        <!-- ✅ show OPD days decided by admin -->
        <td><%= (d.opdDays || []).join(", ") %></td>

        <td>
          <a href="/admin/edit-doctor/<%= d._id %>">Edit</a> |
          <a href="/admin/doctors/<%= d._id %>/leave">Manage Leave</a> |
          <a href="/admin/delete-doctor/<%= d._id %>">Delete</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
