<%- include('partials/header') %>

<h3>Edit Medicine</h3>
<form action="/api/medicines/update/<%= medicine._id %>" method="POST">
  <div class="mb-2">
    <label>Medicine Name</label>
    <input type="text" name="name" class="form-control" value="<%= medicine.name %>">
  </div>
  <div class="mb-2">
    <label>Quantity</label>
    <input type="number" name="quantity" class="form-control" value="<%= medicine.quantity %>">
  </div>
  <div class="mb-2">
    <label>Expiry Date</label>
    <input type="date" name="expiryDate" class="form-control" value="<%= medicine.expiryDate.toISOString().slice(0,10) %>">
  </div>
  <button class="btn btn-primary mt-2">Update Medicine</button>
</form>
 <br>
    <a href="/api/medicines/all">⬅ Back to Dashboard</a>
  </div>
<%- include('partials/footer') %>
