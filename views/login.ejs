<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>MediBridge Pharmacy Login</title>

  <style>
    body {
      font-family: "Poppins", sans-serif;
      height: 100vh;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: url("/images/login-bg.jpg") no-repeat center center/cover;
      position: relative;
    }

    /* Dark transparent overlay */
    .overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.55);
      backdrop-filter: blur(4px);
    }

    .card {
  background: rgba(216, 221, 226, 0.795);
  padding: 35px 40px;
  border-radius: 18px;
  backdrop-filter: blur(37px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  width: 380px;
  transition: transform .3s;
}
.card:hover {
  transform: scale(1.01);
}
h2 {
  text-align: center;
  margin-bottom: 25px;
  color: #0077ff;
  font-weight: 700;
  text-shadow: 0px 2px 5px rgba(0,0,0,0.3);
}
label {
  font-size: 14px;
  font-weight: 600;
  color: #131111;
}
input {
  width: 100%;
  padding: 10px 12px;
  margin: 6px 0 18px 0;
  border-radius: 8px;
  border: none;
  outline: none;
  background: rgba(255,255,255,0.75);
}
input:focus {
  background: white;
  box-shadow: 0px 0px 6px rgba(0, 102, 255, 0.7);
}
button {
  width: 100%;
  padding: 12px;
  background: #0077ff;
  border: none;
  color: white;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  font-size: 15px;
  transition: 0.3s;
}
button:hover {
  background: #005bd0;
  transform: translateY(-2px);
}
.error {
  color: #ff4a4a;
  font-size: 13px;
  margin-bottom: 10px;
  text-align: center;
  background: rgba(255,255,255,0.2);
  padding: 6px;
  border-radius: 6px;
}
.hint {
  font-size: 13px;
  margin-top: 10px;
  color: #080808;
  text-align: center;
}

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

   
  </style>
</head>

<body>
  <div class="overlay"></div>

  <div class="card">
    <h2>MediBridge Pharmacy Login</h2>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <label>Email</label>
      <input type="email" name="email" required placeholder="pharmacy@gmail.com">

      <label>Password</label>
      <input type="password" name="password" required placeholder="********">

      <button type="submit">Login</button>
    </form>

    <div class="hint">
      Don't have an account? Contact admin to register.
    </div>
  </div>
</body>
</html>
