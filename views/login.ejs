<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediBridge | Login</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: url('/images/medibridge_landingpage.jpg') no-repeat center center/cover;
            font-family: "Segoe UI", system-ui, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            position: relative;
            overflow: hidden;
        }

        /* Blur Overlay */
        body::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(4px);
            z-index: -1;
        }

        .login-box {
            width: 380px;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(12px);
            padding: 35px;
            border-radius: 16px;
            box-shadow: 0 8px 28px rgba(0,0,0,0.25);
            text-align: center;
            animation: fadeIn 0.4s ease-in-out;
        }

        h2 {
            font-weight: 800;
            margin-bottom: 25px;
            color: #0b74b1;
        }

        input {
            width: 100%;
            padding: 12px;
            margin-top: 12px;
            border-radius: 10px;
            border: 1.5px solid rgba(0,0,0,0.2);
            font-size: 1rem;
        }

        input:focus {
            outline: none;
            border-color: #0b74b1;
            box-shadow: 0 0 5px rgba(15, 156, 245, 0.4);
        }

        button {
            width: 100%;
            margin-top: 22px;
            padding: 12px;
            border-radius: 10px;
            background: linear-gradient(135deg, #0077b6, #00b4db);
            border: none;
            color: #fff;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: linear-gradient(135deg, #005f86, #00a0c6);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .signup-text {
            margin-top: 14px;
            font-size: 0.95rem;
            color: #1e1e1e;
        }

        .signup-text a {
            color: #0077b6;
            font-weight: 600;
            text-decoration: none;
        }

        .signup-text a:hover {
            text-decoration: underline;
        }

    </style>
</head>
<body>

    <form action="/login" method="post" class="login-box">
        <h2>Login</h2>
        <input type="email" name="email" placeholder="Enter Email" required>
        <input type="password" name="password" placeholder="Enter Password" required>
        <button type="submit">Sign In</button>

        <p class="signup-text">
            Don't have an account? <a href="/register">Register</a>
        </p>
    </form>

</body>
</html>
