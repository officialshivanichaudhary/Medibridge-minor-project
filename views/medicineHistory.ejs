<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Medicine History | MediBridge</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: "Poppins", sans-serif;
      margin: 0;
      min-height: 100vh;
      background: url("/images/login-bg.jpg") center/cover no-repeat fixed;
      backdrop-filter: blur(4px);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 40px 16px;
    }

    /* 🔹 Top bar same as notifications/dashboard  */
    .top-bar {
      width: 100%;
      max-width: 1100px;
      background: #09bac7;
      color: #fff;
      padding: 12px 24px;
      border-radius: 999px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
      margin-bottom: 24px;
    }

    .top-bar .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      font-size: 18px;
    }

     a.back-link {
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.7);
      background: #09bac7;
      transition: 0.2s;
    }

     a.back-link:hover {
      background: #09bac7;
    }

    /* 🔹 Main card */
    .container {
      width: 100%;
      max-width: 1000px;
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.96);
      padding: 40px 28px 60px;
      border-radius: 18px;
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.25);
    }

    h2 {
      text-align: center;
      margin: 0 0 6px;
      font-size: 24px;
      color: #09bac7;
    }

    .subtitle {
      text-align: center;
      font-size: 13px;
      color: #555;
      margin-bottom: 18px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      margin-bottom: 30px;

    }

    th,
    td {
      padding: 10px 12px;
      border-bottom: 1px solid #e1e1e1;
      text-align: center;
    }

    th {
      background: #09bac7;
      color: white;
      font-weight: 600;
    }

    tr:nth-child(even) td {
      background: #fafafa;
    }

    tr:hover td {
      background: #f1f6ff;
    }

    .tag {
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 12px;
      display: inline-block;
    }

    .tag-expired {
      background: #f7b8b8;
      color: #0e0706;
      border: 1px solid #ffc4c4;
    }
  </style>
</head>
<body>

  <!-- 🔹 History card -->
  <div class="container">
    <h2>Expired / Removed Medicine History</h2>
    <div class="subtitle">
      Track all medicines that were removed from stock due to expiry or other reasons.
    </div>

    <table>
      <thead>
        <tr>
          <th>Medicine Name</th>
          <th>Batch</th>
          <th>Qty</th>
          <th>Expiry Date</th>
          <th>Removed On</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% history.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.batchNumber %></td>
            <td><%= item.quantity %></td>
            <td><%= item.expiryDate ? item.expiryDate.toDateString() : "-" %></td>
            <td><%= item.deletedAt ? item.deletedAt.toDateString() : "-" %></td>
            <td>
              <span class="tag tag-expired">
                <%= item.deleteReason %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <a href="/pharmacy/all" class="back-link">← Back to Dashboard</a>
  </div>

</body>
</html>