<!DOCTYPE html>
<html>
<head>
  <title>Register as Blood Donor</title>
</head>
<body>
  <h1>Register as Blood Donor</h1>

  <% if (error) { %>
    <p style="color:red;"><%= error %></p>
  <% } %>

  <% if (message) { %>
    <p style="color:green;"><%= message %></p>
  <% } %>

  <h2>Already a registered patient?</h2>
  <form method="POST" action="/donor/register-existing">
    <label>Registered Email:</label>
    <input type="email" name="email" required>
    <button type="submit">Use My Patient Account</button>
  </form>

  <hr>

  <h2>New Donor</h2>
  <form method="POST" action="/donor/register-new">
    <label>Name:</label>
    <input type="text" name="name" required><br>

    <label>Email:</label>
    <input type="email" name="email" required><br>

    <label>Phone:</label>
    <input type="text" name="phone"><br>

    <label>Blood Group:</label>
    <select name="bloodGroup" required>
      <option value="">Select</option>
      <option value="A+">A+</option>
      <option value="A-">A-</option>
      <option value="B+">B+</option>
      <option value="B-">B-</option>
      <option value="AB+">AB+</option>
      <option value="AB-">AB-</option>
      <option value="O+">O+</option>
      <option value="O-">O-</option>
    </select><br>

    <button type="submit">Register as Donor</button>
  </form>
  <a href="/" class="btn btn-secondary mt-3">← Back to Home</a>

</body>
</html>
