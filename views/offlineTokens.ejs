<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
 <style>
    body {
      background: url('/images/medibridge_landingpage.jpg') no-repeat center/cover fixed;
      font-family: "Segoe UI", sans-serif;
      padding: 50px;
      display: flex;
      justify-content: center;
      margin: 0;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      backdrop-filter: blur(6px);
      z-index: -1;
    }

    .token-box {
      width: 900px;
      background: rgba(255,255,255,0.92);
      padding: 35px 40px;
      border-radius: 20px;
      box-shadow: 0 10px 35px rgba(0,0,0,0.25);
    }

    h1 {
      color: #0077b6;
      font-size: 1.8rem;
      font-weight: 800;
      margin-bottom: 18px;
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 1rem;
      margin-top: 12px;
    }

    th {
      background: #0077b6;
      color: white;
      padding: 12px;
      text-align: center;
    }

    td {
      background: rgba(255,255,255,0.85);
      text-align: center;
      padding: 10px;
      border-bottom: 1px solid rgba(0,0,0,0.12);
      font-weight: 500;
    }

    tr:hover td {
      background: rgba(0,119,182,0.08);
    }

    .no-data {
      font-weight: 600;
      padding: 18px;
      color: #444;
    }

    .back-btn {
      display: inline-block;
      text-align: center;
      background: transparent;
      border: 2px solid #0077b6;
      color: #0077b6;
      padding: 10px 18px;
      font-weight: 700;
      border-radius: 10px;
      margin-top: 20px;
      text-decoration: none;
      font-size: 1rem;
      transition: 0.25s;
    }

    .back-btn:hover {
      background: #0077b6;
      color: #fff;
    }
  </style>


</head>
<body>
     <div class="token-box">
<h1>Today's Offline Tokens</h1>

<table border="1" cellpadding="10" style="border-collapse:collapse; width:100%;">
    <thead style="background:#f2f2f2; font-weight:bold;">
        <tr>
            <th>Token</th>
            <th>Patient Name</th>
            <th>Doctor</th>
            <th>Department</th>
            <th>Generated At</th>
        </tr>
    </thead>
    <tbody>
        <% if (tokens.length === 0) { %>
            <tr>
                <td colspan="5" style="text-align:center;">No offline tokens generated today.</td>
            </tr>
        <% } else { %>
            <% tokens.forEach(t => { %>
                <tr>
                    <td><%= t.customToken %></td>
                    <td><%= t.offlineName %></td>
                    <td><%= t.doctor.name %></td>
                    <td><%= t.doctor.department %></td>
                    <td><%= new Date(t.createdAt).toLocaleTimeString() %></td>
                </tr>
            <% }) %>
        <% } %>
    </tbody>
</table>

<a href="/admin/Dashboard">← Back to Dashboard</a>


</div>
</body>
</html>