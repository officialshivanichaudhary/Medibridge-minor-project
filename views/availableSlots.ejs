<!DOCTYPE html>
<html>
<head>
  <title>Available Slots</title>
  <style>
    body { font-family: Poppins, sans-serif; background: #fafafa; padding: 20px;  background: url('/images/medibridge_landingpage.jpg') no-repeat center/cover fixed;
    margin: 0;
    font-family: "Segoe UI", sans-serif;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 0;}
    h2 { margin-bottom: 10px; }
    .legend span { padding: 6px 12px; border-radius: 5px; margin-right: 8px; font-size: 14px; }
    .available { background: #a8e6a3; }
    .booked { background-color: red; color: white; cursor: not-allowed; }

    .slots { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
    .slot-btn { padding: 8px 12px; border: none; border-radius: 6px; cursor: pointer; transition: 0.2s; }
    .slot-btn.available { background: #4CAF50; color: white; }
    .slot-btn.booked { background: #f44336; color: white; cursor: not-allowed; }

    @keyframes bookedFlash {
      0% { background-color: #f44336; transform: scale(1); }
      50% { background-color: #ff7b7b; transform: scale(1.1); }
      100% { background-color: #f44336; transform: scale(1); }
    }
    .flash-booked {
      animation: bookedFlash 1s ease;
    }
    body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(5px);
    z-index: -1;
}

/* White Card */
.container-box {
    width: 850px;
    background: rgba(255,255,255,0.94);
    padding: 30px 40px;
    border-radius: 20px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.28);
}

/* Titles */
h2, h3 {
    color: #0077b6;
    font-weight: 800;
}

legend, label, p {
    color: #002c45;
    font-weight: 600;
}

/* Slots (KEEPING COLORS SAME AS YOURS) */
.slots { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 10px; 
    margin-top: 10px; 
}

.slot-btn {
    padding: 10px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
}

hr {
    opacity: 0.5;
    margin: 18px 0;
}

/* Back Button */
a.btn {
    display: inline-block;
    margin-top: 18px;
    padding: 12px 20px;
    background: #0077b6;
    color: #fff;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
}
a.btn:hover {
    background: #005f87;
}

/* Legend Styling */
.legend span {
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    display: inline-block;
    margin: 4px 8px 10px 0;
}
  </style>
</head>

<body>
<div class="container-box">
  <h2>Department: <%= departmentName %></h2>

  <div class="legend">
    <span class="available">Available</span>
    <span class="booked">Booked</span>
  </div>

  <% if (!availableDays || availableDays.length === 0) { %>
    <p>No OPD slots available for the next 7 days.</p>
  <% } %>

  <% availableDays.forEach(day => { %>
    <h3>
      <%= day.date %> 
      <span style="color:#444;">(<%= day.dayName %>)</span>
      <br>
      <span style="font-size:15px; color:#222;">
        Doctor: <b><%= day.doctor.name %></b> 
        (<%= day.doctor.department %>)
      </span>
    </h3>

    <div class="slots">
<% day.slots.forEach(slot => { 
  const cleanId = slot.time.replace(/[: ]/g, '').toUpperCase(); 
%>

  <% if (day.doctor && day.doctor.id) { %>

    <form method="POST" action="/book-token" style="display:inline;">
      
      <input type="hidden" name="department" value="<%= departmentName %>">
      <input type="hidden" name="patientId" value="<%= patientId %>">
      <input type="hidden" name="selectedDate" value="<%= day.date %>">
      <input type="hidden" name="timeSlot" value="<%= slot.time %>">
      
      <!-- 🔥 IMPORTANT FIX -->
      <input type="hidden" name="doctorId" value="<%= day.doctor.id %>">

      <input type="hidden" name="mode" value="Online">
      <input type="hidden" name="problem" value="">

      <button 
        class="slot-btn <%= slot.booked ? 'booked' : 'available' %>"
        <%= slot.booked ? 'disabled' : '' %>
      >
        <%= slot.time %>
      </button>

    </form>

  <% } else { %>

    <!-- ❌ doctor nahi hai → disabled -->
    <button class="slot-btn booked" disabled>
      <%= slot.time %>
    </button>

  <% } %>

<% }) %>

    </div>
    <hr>
  <% }) %>
<a href="/" class="btn btn-primary mt-3">Go Back to Home</a>

  <script>
    function askProblem(form) {
      const p = prompt("Describe your problem:");
      if (!p) return false;
      form.problem.value = p;
      return true;
    }
  </script>

  <!-- Real-time update -->
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();

    socket.on("slotBooked", (data) => {
    const cleanedTime = data.timeSlot.replace(/[: ]/g, '').toUpperCase();
      const cleanedDate = data.date.replace(/-/g, '');
      const btnId = `slot-${cleanedDate}-${cleanedTime}`;

      const btn = document.getElementById(btnId);

      if (btn) {
        btn.classList.remove("available");
        btn.classList.add("booked", "flash-booked");
        btn.disabled = true;
        btn.innerText = `${data.timeSlot} (Booked)`;
        setTimeout(() => btn.classList.remove("flash-booked"), 1200);
      }
    });
  </script>
</div>
</body>
</html>