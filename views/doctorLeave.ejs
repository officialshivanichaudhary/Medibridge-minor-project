<!DOCTYPE html>
<html>
<head>
  <title>Manage Leave - <%= doctor.name %></title>

<style>
    body {
      background: url('/images/medibridge_landingpage.jpg') no-repeat center/cover fixed;
      font-family: "Segoe UI", sans-serif;
      display: flex;
      justify-content: center;
      padding: 40px;
      margin: 0;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      backdrop-filter: blur(6px);
      z-index: -1;
    }

    .leave-box {
      width: 520px;
      background: rgba(255,255,255,0.92);
      padding: 30px 36px;
      border-radius: 18px;
      box-shadow: 0 10px 35px rgba(0,0,0,0.25);
    }

    h1 {
      font-size: 1.5rem;
      color: #0077b6;
      font-weight: 800;
      margin-bottom: 20px;
      text-align: center;
    }

    h3 {
      margin-top: 28px;
      color: #003b55;
      font-weight: 700;
    }

    input, textarea {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      border: 1.5px solid rgba(0,0,0,0.25);
      border-radius: 10px;
      font-size: 1rem;
    }

    button {
      width: 100%;
      margin-top: 18px;
      padding: 12px;
      background: #0077b6;
      color: #fff;
      border: none;
      font-size: 1rem;
      font-weight: 700;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background: #005f87;
    }

    ul li {
      padding: 6px 0;
      font-weight: 600;
      color: #1b1b1b;
    }

    .back-btn {
      display: block;
      text-align: center;
      background: transparent;
      border: 2px solid #0077b6;
      color: #0077b6;
      padding: 10px;
      font-weight: 700;
      border-radius: 10px;
      margin-top: 15px;
      text-decoration: none;
      transition: 0.25s;
    }
    .back-btn:hover {
      background: #0077b6;
      color: #fff;
    }

    /* Error / Success Text */
    .msg-error { color: #e53935; font-weight: 700; }
    .msg-success { color: #2e7d32; font-weight: 700; }

  </style>

</head>
<body>
 <div class="leave-box">
  <h1>Manage Leave for <%= doctor.name %> (<%= doctor.department %>)</h1>

  <% if (todayDay && !doctor.opdDays.includes(todayDay)) { %>
      <p style="color: red;">Doctor does not have OPD on <%= todayDay %>.</p>
  <% } %>

  <% if (error) { %>
    <p style="color: red;"><%= error %></p>
  <% } %>

  <% if (success) { %>
    <p style="color: green;"><%= success %></p>
  <% } %>

  <form method="POST" action="/admin/doctors/<%= doctor._id %>/leave">
    <label>Leave Date:</label>
    <input
      type="date"
      name="leaveDate"
      min="<%= todayStr %>"
      required
    />

    <br><br>

    <label>Reason (optional):</label><br>
    <textarea name="reason" rows="3" cols="40"></textarea>

    <br><br>
    <button type="submit">Save Leave</button>
  </form>

  <hr>

  <h3>Upcoming Leaves</h3>

  <ul>
    <% if (upcomingLeaves.length > 0) { %>
      <% upcomingLeaves.forEach(l => { %>
        <li><%= l.date %></li>
      <% }) %>
    <% } else { %>
      <li>No upcoming leaves.</li>
    <% } %>
  </ul>

  <p><a href="/admin/doctors">Back to Doctors List</a></p>
  </div>
</body>
</html>
